# Optional: override the gateway auth token (default for local dev is dev-token-local-only).
# OPENCLAW_GATEWAY_TOKEN=dev-token-local-only

# Required for agent runs: Google Vertex (Gemini) via service account.
# Paste your full service account JSON as a single line (minified, no newlines). The entrypoint
# writes it to a file and sets GOOGLE_APPLICATION_CREDENTIALS so the google-vertex provider can use it.
# Create key: Google Cloud Console → IAM → Service accounts → Keys → Add key → JSON.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
